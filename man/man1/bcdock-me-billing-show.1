.nh
.TH "BCDOCK" "1" "Jan 2025" "BCDock CLI" "BCDock Manual"

.SH NAME
bcdock-me-billing-show - Show current plan, subscription state, and last 12 invoices


.SH SYNOPSIS
\fBbcdock me billing show [flags]\fP


.SH DESCRIPTION
Print a snapshot of your billing state: active plan (tier, rates, env cap),
Stripe subscription status, last 12 invoices, and attached payment method.

.PP
For ongoing card / plan management use 'bcdock me billing portal' to open the
Stripe Customer Portal in a browser.

.PP
Exit codes:
  0   ok
  1   general error
  3   auth failure (missing or invalid token)
  4   rate-limited


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for show


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-url\fP=""
	API base URL (env: BCDOCK_API_URL)

.PP
\fB--no-color\fP[=false]
	Disable colored output

.PP
\fB-o\fP, \fB--output\fP="table"
	Output format: table, json, csv

.PP
\fB-q\fP, \fB--quiet\fP[=false]
	Suppress non-essential output

.PP
\fB--timeout\fP=30s
	Request timeout

.PP
\fB--token\fP=""
	API token (env: BCDOCK_TOKEN)


.SH EXAMPLE
.EX
  bcdock me billing show
  bcdock me billing show -o json
.EE


.SH SEE ALSO
\fBbcdock-me-billing(1)\fP
