.nh
.TH "BCDOCK" "1" "Jan 2025" "BCDock CLI" "BCDock Manual"

.SH NAME
bcdock - BCDock CLI \- manage Business Central environments


.SH SYNOPSIS
\fBbcdock [flags]\fP


.SH DESCRIPTION
BCDock CLI wraps the BCDock Platform API for use in terminals,
scripts, and AI agent workflows.

.PP
Set BCDOCK_TOKEN to authenticate without --token.  (env: BCDOCK_TOKEN)
Set BCDOCK_API_URL to target a different API endpoint.  (env: BCDOCK_API_URL)

.PP
See 'bcdock help authentication' for token-source precedence and CI/CD guidance.
See 'bcdock help agent-workflows' for recipes for Claude, Copilot, and similar.

.PP
Exit codes:
  0   ok
  1   general error
  3   auth failure (missing or invalid token)
  4   rate-limited
  5   not found
  10  provisioning failed
  124 timeout


.SH OPTIONS
\fB--api-url\fP=""
	API base URL (env: BCDOCK_API_URL)

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for bcdock

.PP
\fB--no-color\fP[=false]
	Disable colored output

.PP
\fB-o\fP, \fB--output\fP="table"
	Output format: table, json, csv

.PP
\fB-q\fP, \fB--quiet\fP[=false]
	Suppress non-essential output

.PP
\fB--timeout\fP=30s
	Request timeout

.PP
\fB--token\fP=""
	API token (env: BCDOCK_TOKEN)


.SH EXAMPLE
.EX
  bcdock env list
  bcdock env create --name my-env --version 25.5 --country au --region westus2 --wait
  bcdock auth whoami
.EE


