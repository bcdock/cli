.nh
.TH "BCDOCK" "1" "Jan 2025" "BCDock CLI" "BCDock Manual"

.SH NAME
bcdock-config-regions - List available Azure regions


.SH SYNOPSIS
\fBbcdock config regions [flags]\fP


.SH DESCRIPTION
List the Azure regions where BCDock can provision environments.

.PP
Use the REGION column value as --region in 'env create' and 'artifacts list'.

.PP
Exit codes:
  0   ok
  3   auth failure (missing or invalid token)
  4   rate-limited


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for regions


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-url\fP=""
	API base URL (env: BCDOCK_API_URL)

.PP
\fB--no-color\fP[=false]
	Disable colored output

.PP
\fB-o\fP, \fB--output\fP="table"
	Output format: table, json, csv

.PP
\fB-q\fP, \fB--quiet\fP[=false]
	Suppress non-essential output

.PP
\fB--timeout\fP=30s
	Request timeout

.PP
\fB--token\fP=""
	API token (env: BCDOCK_TOKEN)


.SH EXAMPLE
.EX
  bcdock config regions
  bcdock config regions -o json
.EE


.SH SEE ALSO
\fBbcdock-config(1)\fP
