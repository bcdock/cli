.nh
.TH "BCDOCK" "1" "Jan 2025" "BCDock CLI" "BCDock Manual"

.SH NAME
bcdock-artifacts-countries - List countries with active BC artifact versions


.SH SYNOPSIS
\fBbcdock artifacts countries [flags]\fP


.SH DESCRIPTION
List all BC localisation country codes that have at least one active artifact
version in the BCDock catalog.

.PP
Use the CODE column as the --country value for 'artifacts list' and 'env create'.

.PP
Exit codes:
  0   ok
  3   auth failure (missing or invalid token)
  4   rate-limited


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for countries


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-url\fP=""
	API base URL (env: BCDOCK_API_URL)

.PP
\fB--no-color\fP[=false]
	Disable colored output

.PP
\fB-o\fP, \fB--output\fP="table"
	Output format: table, json, csv

.PP
\fB-q\fP, \fB--quiet\fP[=false]
	Suppress non-essential output

.PP
\fB--timeout\fP=30s
	Request timeout

.PP
\fB--token\fP=""
	API token (env: BCDOCK_TOKEN)


.SH EXAMPLE
.EX
  bcdock artifacts countries
  bcdock artifacts countries -o json
.EE


.SH SEE ALSO
\fBbcdock-artifacts(1)\fP
